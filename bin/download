#!/usr/bin/env bash
# bin/download
set -euo pipefail

# A las versiones en GitHub normalmente se les pone una 'v' al inicio (ej: v1.1.0)
VERSION="v${ASDF_INSTALL_VERSION}"
DOWNLOAD_PATH=$ASDF_DOWNLOAD_PATH

# 1. Detectar OS y Arquitectura
OS="$(uname -s | tr '[:upper:]' '[:lower:]')"
ARCH="$(uname -m)"

if [ "$ARCH" = "x86_64" ]; then ARCH="amd64"; fi
if [ "$ARCH" = "aarch64" ] || [ "$ARCH" = "arm64" ]; then ARCH="arm64"; fi

# 2. Construir la URL basándonos en su script
URL="https://github.com/extism/cli/releases/download/${VERSION}/extism-${VERSION}-${OS}-${ARCH}.tar.gz"

echo "Descargando extism versión ${ASDF_INSTALL_VERSION} desde $URL..."

# 3. Descargar y extraer
mkdir -p "$DOWNLOAD_PATH"
curl -fsSL "$URL" -o "$DOWNLOAD_PATH/extism.tar.gz"

# Extraemos el contenido del tar.gz en la carpeta temporal de descarga
tar -xzf "$DOWNLOAD_PATH/extism.tar.gz" -C "$DOWNLOAD_PATH"