#!/usr/bin/env bash
# bin/install
set -euo pipefail

INSTALL_PATH=$ASDF_INSTALL_PATH
DOWNLOAD_PATH=$ASDF_DOWNLOAD_PATH

echo "Instalando extism en $INSTALL_PATH..."

# Creamos la carpeta bin final
mkdir -p "$INSTALL_PATH/bin"

# Movemos SOLAMENTE el ejecutable extism a la carpeta bin
cp "$DOWNLOAD_PATH/extism" "$INSTALL_PATH/bin/extism"
chmod +x "$INSTALL_PATH/bin/extism"

echo "¡extism instalado correctamente!"